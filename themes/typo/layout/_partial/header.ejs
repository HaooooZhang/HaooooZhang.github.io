<header class="header">
  <section class="header-container">
    <div class="logo-wrap">
      <% if (is_home()) { %>
      <button class="index-toggle" type="button" aria-label="Toggle index" data-index-toggle aria-expanded="false">
        <i class="fa-solid fa-bars" aria-hidden="true"></i>
      </button>
      <% } %>
      <a class="logo" href="<%- url_for() %>"><%= config.title %></a>
    </div>
    <ul class="nav">
      <% for (name in theme.menu) { %>
      <li><a href="<%- url_for(theme.menu[name]) %>"><%= name %></a></li>
      <% } %>
    </ul>
  </section>
</header>